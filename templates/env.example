# ---------------------------------------------------------------------------
# Example environment file — copy to `.env` and fill in real values.
# NEVER commit a real `.env`. Only `.env.example` is tracked by git.
#
# Group variables by concern and document each one.
# ---------------------------------------------------------------------------

# --- Runtime ---
# Logging level: debug | info | warn | error
LOG_LEVEL=info
# NODE_ENV=development

# --- AI provider ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- HTTP server (if applicable) ---
# PORT=3000

# --- Datastores (if applicable) ---
# DATABASE_URL=
# VECTOR_DB_URL=
