# Copy to `.env` and fill in real values.  `.env` is git-ignored; this file is committed.
#   cp .env.example .env

# --- App -------------------------------------------------------------------
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
PORT=3000

# Which storage backend to use: postgres | memory
# This single variable is the "swap". No code changes either way.
STORAGE=postgres

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=authuser
POSTGRES_PASSWORD=replace_with_a_password
POSTGRES_DB=authdb

# Used when you run the app on your HOST (npm start) and Postgres in Docker.
# Inside `docker compose`, the app instead reaches the database at host `db` —
# docker-compose.yml overrides DATABASE_URL for that case.
DATABASE_URL=postgres://authuser:replace_with_a_password@localhost:5432/authdb

# --- Redis (stretch; optional) ---------------------------------------------
# Left unset when running on the host. docker-compose sets it to redis://redis:6379
# REDIS_URL=redis://localhost:6379
