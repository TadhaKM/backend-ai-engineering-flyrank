# Copy this file to `.env` and fill in a real secret.
#   cp .env.example .env
#
# `.env` is git-ignored. `.env.example` IS committed, so other developers learn
# WHICH variables exist without ever learning their VALUES.

# The key used to sign and verify JWTs. Anyone who knows this can forge a login
# token for any user, so treat it like a password. Generate a long random one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# The port the server listens on.
PORT=3000
