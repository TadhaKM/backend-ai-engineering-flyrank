# Assignment 04 — configuration.
#
# Every value here has a working default in `scraper/config.py`; nothing is secret
# and the scraper runs with no .env at all. Copy to `.env` only if you want to
# change something without passing a CLI flag every time.
#
# Precedence:  CLI flag  >  environment variable  >  default in config.py

# --- Identity ---------------------------------------------------------------
# Goes into the User-Agent so a site owner can contact whoever is crawling them.
# Change this to YOUR email or GitHub before running.
SCRAPER_CONTACT=marepalt@tcd.ie

# --- Politeness -------------------------------------------------------------
SCRAPER_DELAY=1.5          # seconds between requests (robots.txt may raise this)
SCRAPER_JITTER=0.4         # random extra, 0..N seconds, added on top
SCRAPER_TIMEOUT=10         # per-request timeout, seconds

# --- Retries ----------------------------------------------------------------
SCRAPER_MAX_ATTEMPTS=3     # total tries per URL, so 2 retries
SCRAPER_OVERLOAD_MULTIPLIER=3.0   # back off this much harder on a 429 / 503

# --- Scope ------------------------------------------------------------------
SCRAPER_MAX_PAGES=5        # listing pages to walk
SCRAPER_MAX_BOOKS=100      # hard cap on records — keeps a practice run polite

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=info             # debug | info | warning | error
