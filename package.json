{
  "name": "backend-ai-engineering-flyrank",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend AI engineering internship workspace — a growing portfolio of self-contained assignments.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared",
    "assignments/*",
    "extras/*"
  ],
  "scripts": {
    "new:assignment": "node scripts/new-assignment.mjs",
    "lint": "eslint . --ext .ts,.tsx,.mts,.cts",
    "lint:fix": "eslint . --ext .ts,.tsx,.mts,.cts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
