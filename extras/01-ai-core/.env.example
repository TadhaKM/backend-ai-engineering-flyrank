# ---------------------------------------------------------------------------
# Assignment 01 — AI Core — example environment
#
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Server ---
PORT=3000
# debug | info | warn | error
LOG_LEVEL=info

# --- AI model + behaviour (all swappable via config; nothing hardcoded) ---
# Logical provider name (routing hint for the gateway).
AI_PROVIDER=anthropic
# Model id. Default is Anthropic's current flagship.
AI_MODEL=claude-opus-4-8
# Max output tokens per response (<= 128000).
AI_MAX_TOKENS=4096
# Extended thinking: adaptive | disabled. Disabled keeps the structured endpoint
# fast + deterministic; set adaptive for harder multi-step reasoning.
AI_THINKING=disabled
# Optional effort hint: low | medium | high | xhigh | max (omit to use the API default).
# AI_EFFORT=medium
# Safety cap on the tool-use loop.
AI_MAX_TOOL_ITERATIONS=8

# --- Portkey AI Gateway (all Claude traffic is routed through this) ---
# Portkey API key (from the Portkey dashboard).
PORTKEY_API_KEY=
# Gateway base URL (change to a self-hosted gateway if you run one).
PORTKEY_BASE_URL=https://api.portkey.ai/v1
#
# How Portkey authenticates the upstream provider — pick ONE:
#
#   (A) Saved integration — RECOMMENDED, and REQUIRED if your Portkey workspace has
#       `block_inline_config` enabled (a bare provider name is then rejected):
#           PORTKEY_PROVIDER=@your-integration-slug   # note the leading '@', e.g. @anthropic
#       The integration stores the Anthropic key, so ANTHROPIC_API_KEY below can be blank.
#   (B) Portkey Virtual Key:
#           PORTKEY_PROVIDER=anthropic
#           PORTKEY_VIRTUAL_KEY=vk-...
#   (C) Inline (only if your workspace allows it): PROVIDER=anthropic + ANTHROPIC_API_KEY below.
PORTKEY_PROVIDER=@anthropic
# PORTKEY_VIRTUAL_KEY=

# --- Anthropic (used only in inline mode (C); leave blank for a saved integration) ---
ANTHROPIC_API_KEY=
